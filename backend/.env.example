# ── Application Settings ───────────────────────────────────────
DEBUG=false
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── API Server Configuration ───────────────────────────────────
HOST=0.0.0.0
PORT=8000
# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Database Configuration ─────────────────────────────────────
# By default, runs against local Docker-hosted Postgres:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/plum_claims
# Example for Cloud Supabase connection:
# DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.[project-id].supabase.co:5432/postgres

# ── Redis & Celery Configuration ───────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AI LLM Providers & Failover Chain ──────────────────────────
# The system initiates the ModelClient using the following priority:
# 1. Google Gemini (Primary choice for low latency and high quality vision OCR)
# 2. OpenAI GPT-4o-mini (Fallback if Gemini is down)
# 3. OpenRouter (Secondary fallback supporting alternative models)

# Google API Configuration
GOOGLE_API_KEY=your_gemini_api_key_here
GOOGLE_MODEL=gemini-2.0-flash

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# OpenRouter Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash

# General AI Settings
AI_TEMPERATURE=0.1
AI_MAX_RETRIES=3
AI_TIMEOUT_SECONDS=60.0

# ── Storage Configuration ──────────────────────────────────────
# Folder on disk to store uploaded scans temporarily
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20
